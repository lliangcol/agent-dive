flowchart TD
  user["User / coding task"] --> host["AI coding host"]
  host --> adapter["Host adapter"]
  adapter --> hooks["Lifecycle hooks"]
  adapter --> commands["Commands and skills"]
  hooks --> config["Mode config resolver"]
  hooks --> builder["Instruction builder"]
  commands --> skills["skills/*.md"]
